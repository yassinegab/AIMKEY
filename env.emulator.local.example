# Copiez ce fichier vers .env.local ou lancez : npm run prepare:local
# Mode 100 % local : Auth + Firestore émulateurs (pas de projet Google requis pour dev)

NEXT_PUBLIC_FIREBASE_USE_EMULATOR=true
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-dima-gabes

# Optionnel (ports par défaut 9099 / 8080)
# NEXT_PUBLIC_FIREBASE_EMULATOR_HOST=127.0.0.1
# NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_PORT=9099
# NEXT_PUBLIC_FIREBASE_FIRESTORE_EMULATOR_PORT=8080

# Chat IA (Gemini) — clé serveur si vous testez le chatbot
# GEMINI_API_KEY=
