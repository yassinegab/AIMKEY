# --- Option A : dev local SANS projet Google (recommandé pour tester) ---
# 1) npm run prepare:local   → crée .env.local depuis env.emulator.local.example
# 2) npm run dev:stack      → émulateurs Auth+Firestore + Next.js
# Interface émulateurs : http://localhost:4000

# --- Option B : Firebase en production (console Google) ---
# Console : activer Authentication (Email/mot de passe) + créer la base Firestore.
# Déployer les règles : npx -y firebase-tools@latest deploy --only firestore
# Console Firebase > Paramètres du projet > Vos applications > Web > Config SDK
# Ou: npx -y firebase-tools@latest apps:sdkconfig WEB_APP_ID
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
# Optionnel (Analytics)
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""

# Chatbot اسألني (route /api/chat) — Gemini — clé **serveur uniquement**, jamais NEXT_PUBLIC_*
# Google AI Studio : https://aistudio.google.com/apikey
GEMINI_API_KEY=""
# Optionnel : ex. gemini-2.5-flash, gemini-2.0-flash
# GEMINI_API_MODEL="gemini-2.5-flash"
#
# Sécurité : activer la vérification e-mail + reset mot de passe dans Firebase Console → Authentication → Templates.
# Les clés API Firebase côté client (NEXT_PUBLIC_*) sont publiques par conception ; la protection repose sur les domaines autorisés + règles Firestore.

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
